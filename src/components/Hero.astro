---
import type { HeroProps } from "@types";
type Props = HeroProps;

const { name, specialty, summary, email } = Astro.props;
const emailSubject = encodeURIComponent("Let's build something great");
---

<section class="py-24 md:py-32" id="hero">
  <h1
    class="mb-1.5 font-serif text-7xl font-bold tracking-tightest text-white sm:text-8xl md:mb-0 md:text-9xl"
  >
    {name}
  </h1>
  <p
    class="mb-9 font-serif text-4xl leading-11.5 font-bold tracking-tighter text-primary sm:text-5xl md:text-6xl"
  >
    {specialty}
  </p>
  <p class="mb-16 text-base font-normal text-neutral md:text-lg">
    {summary}
  </p>

  <div class="mb-16 flex flex-wrap items-center gap-4">
    <a
      href={`mailto:${email}?subject=${emailSubject}`}
      class="inline-flex items-center gap-2 rounded-lg bg-primary px-6 py-3 text-base font-medium text-white no-underline transition-colors hover:bg-primary/90"
    >
      Let's build something great
      <svg viewBox="0 0 24 24" fill="none" class="h-4 w-4" aria-hidden="true">
        <path
          d="M5 12h14M13 6l6 6-6 6"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
    </a>
  </div>
</section>
