---
import type { CredentialProps, SkillCategoryProps } from "@types";

interface Props {
  skills: SkillCategoryProps[];
  credentials: CredentialProps[];
}

const { skills, credentials } = Astro.props;
---

<section id="skills" class="border-t border-neutral/20 py-24">
  <div class="mb-18">
    <h2
      class="mb-8 text-sm font-semibold tracking-[0.08em] text-white/70 uppercase"
    >
      Skills
    </h2>
    <div class="grid gap-4 md:grid-cols-3">
      {
        skills.map(({ title, items }) => (
          <article class="rounded-2xl border border-neutral/15 bg-white/3 p-6">
            <h3 class="mb-4 text-lg font-semibold text-white">{title}</h3>
            <ul class="space-y-1.5 text-base text-white/85">
              {items.map((item) => (
                <li class="text-sm text-white/85">{item}</li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </div>

  <h2
    class="mb-6 text-sm font-semibold tracking-[0.08em] text-white/70 uppercase"
  >
    Patents & Certifications
  </h2>
  <ul class="divide-y divide-neutral/20 border-y border-neutral/20">
    {
      credentials.map(({ type, title, subtitle }) => (
        <li class="flex gap-4 py-6">
          <span class="mt-1 inline-flex h-6 w-6 shrink-0 items-center justify-center text-white/70">
            {type === "patent" ? (
              <svg
                viewBox="0 0 24 24"
                fill="none"
                class="h-5 w-5"
                aria-hidden="true"
              >
                <rect
                  x="3"
                  y="4"
                  width="18"
                  height="16"
                  rx="2"
                  stroke="currentColor"
                  stroke-width="1.5"
                />
                <path
                  d="M8 9h8M8 13h4"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                />
                <circle
                  cx="17"
                  cy="15"
                  r="2"
                  stroke="currentColor"
                  stroke-width="1.5"
                />
              </svg>
            ) : (
              <svg
                viewBox="0 0 24 24"
                fill="none"
                class="h-5 w-5"
                aria-hidden="true"
              >
                <path
                  d="M12 4 3 8l9 4 9-4-9-4Z"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linejoin="round"
                />
                <path
                  d="M6 10v4c0 1.5 2.7 2.8 6 2.8s6-1.3 6-2.8v-4"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                />
              </svg>
            )}
          </span>
          <div>
            <p class="text-sm tracking-tight text-white">{title}</p>
            {/* <p class="mt-1 text-base text-white/65">{subtitle}</p> */}
          </div>
        </li>
      ))
    }
  </ul>
</section>
